upstream redmine {
{% for backend in redmine_backends %}
    server 127.0.0.1:{{ backend.port }};
{% endfor %}
}

server {
    listen {{ redmine_port }} default_server;
    listen [::]:{{ redmine_port }} default_server;
    listen 80 default_server;
    listen [::]:80 default_server;

    server_name {{ redmine_domain }};

    location ^~ /.well-known/acme-challenge/ {
        root {{ letsencrypt_webroot }};
        default_type text/plain;
    }

    location / {
        proxy_pass http://redmine;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

{% if redmine_ssl_enabled | default(false) %}
server {
    listen 443 ssl;
    listen [::]:443 ssl;

    server_name {{ redmine_domain }};

    ssl_certificate /etc/letsencrypt/live/{{ redmine_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ redmine_domain }}/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://redmine;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
{% endif %}
